// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ===== USER =====
model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  // Relations
  measurements  Measurement[]
  workouts      Workout[]
  meals         Meal[]
  videos        Video[]
  progressPhotos ProgressPhoto[]
  morphoAnalyses MorphoAnalysis[]
  exerciseNotes  ExerciseNote[]
}

// ===== MEASUREMENTS (Body Composition) =====
model Measurement {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  // Body measurements
  weight      Float?   // kg
  bodyFat     Float?   // %
  muscleMass  Float?
  bmi         Float?

  // Claude Vision data
  claudeData  Json?    // Raw data from Claude Vision

  // BodyScore data
  bodyScoreId String?  // BodyScore AI ID
  bodyScoreData Json?  // Raw data from BodyScore

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([createdAt])
}

// ===== WORKOUTS (Hevy integration) =====
model Workout {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  // Hevy data
  hevyId      String?  // Hevy workout ID
  name        String
  description String?

  // Stats
  duration    Int?     // minutes
  calories    Int?
  volume      Float?   // total weight lifted

  completedAt DateTime
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  // Relations
  exercises   Exercise[]     @relation("WorkoutExercises")
  exerciseSets ExerciseSet[] @relation("WorkoutExerciseSets")
  aiFeedback  Json?          // AI coach feedback

  @@index([userId])
  @@index([completedAt])
}

// ===== EXERCISES =====
model Exercise {
  id          String   @id @default(cuid())
  workoutId   String
  workout     Workout  @relation("WorkoutExercises", fields: [workoutId], references: [id], onDelete: Cascade)

  name        String
  sets        ExerciseSet[] @relation("ExerciseSets")

  createdAt   DateTime @default(now())

  @@index([workoutId])
}

// ===== EXERCISE SETS =====
model ExerciseSet {
  id          String   @id @default(cuid())
  workoutId   String
  workout     Workout  @relation("WorkoutExerciseSets", fields: [workoutId], references: [id], onDelete: Cascade)
  exerciseId  String
  exercise    Exercise @relation("ExerciseSets", fields: [exerciseId], references: [id], onDelete: Cascade)

  // Basic set data
  reps        Int
  weight      Float    // kg
  rpe         Float?   // Rate of Perceived Exertion (1-10)
  duration    Int?     // seconds

  // Hevy-specific fields
  setType     String   @default("normal")  // normal, warmup, drop, failure
  oneRm       Float?   // Estimated 1RM
  isToFailure Boolean  @default(false)
  isWarmup   Boolean  @default(false)
  isDropSet Boolean  @default(false)
  setIndex   Int      @default(0)  // Order within exercise
  supersetIds Int[]    @default([])  // Superset group IDs

  // AI feedback
  formScore   Float?   // 0-100
  feedback    String?

  createdAt   DateTime @default(now())

  @@index([exerciseId])
  @@index([workoutId])
}

// ===== MEALS (Nutrition - Journal Santé) =====
model Meal {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  // Journal Santé data
  journalId   String?  // Journal Santé meal ID

  // Meal data
  name        String
  type        String   // breakfast, lunch, dinner, snack
  time        DateTime

  // Nutrition
  calories    Int
  protein     Float    // g
  carbs       Float    // g
  fats        Float    // g
  fiber       Float?   // g
  sugar       Float?   // g

  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([userId])
  @@index([time])
}

// ===== VIDEOS (MediaPipe analysis) =====
model Video {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  // Video data
  exercise    String   // exercise name
  url         String   // video URL (Drive storage)
  duration    Int      // seconds

  // AI analysis
  poseData    Json?    // MediaPipe pose data
  repCount    Int?
  formScore   Float?   // 0-100
  feedback    String?
  keypoints   Json?    // detected keypoints

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([exercise])
}

// ===== PROGRESS PHOTOS =====
model ProgressPhoto {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  // Photo data
  url         String   // photo URL (Drive storage)
  angle       String   // front, side, back
  notes       String?

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([createdAt])
}

// Weekly morpho-anatomical analysis: combines the 3 weekly photos with the
// user's Hevy exercises to produce segment estimates and exercise-adaptation advice.
model MorphoAnalysis {
  id          String   @id @default(cuid())
  userId      String
  user        User     @relation(fields: [userId], references: [id])

  weekOf      DateTime            // Monday of the ISO week this analysis covers
  photoIds    String[] @default([])  // ProgressPhoto ids (front/side/back)

  segments    Json?               // estimated segment lengths / proportions
  advice      Json?               // structured advice to adapt the exercises
  progression Json?               // qualitative progression vs. previous week
  summary     String?             // short human-readable summary

  claudeModel String?
  raw         Json?               // raw model output (audit)
  emailedAt   DateTime?           // when the advice email was sent

  createdAt   DateTime @default(now())

  @@index([userId])
  @@index([weekOf])
}

// Freeform context notes about how exercises are actually executed (bilateral vs
// unilateral, load convention, deliberate tempo/technique choices...) that Hevy's
// raw sets/reps/weight can't capture. Fed into the morpho + video analysis prompts
// so Claude doesn't misread the numbers or the movement.
model ExerciseNote {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id])

  // Exact Exercise.name to attach to, or null for a general note (applies to all).
  exerciseName  String?
  note          String

  // Optional validity window (e.g. "since mid-May"); null = always active.
  activeFrom    DateTime?
  activeUntil   DateTime?

  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  @@index([userId])
  @@index([exerciseName])
}